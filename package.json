{
  "name": "my-site",
  "version": "0.1.0",
  "description": "Static site with Cloudflare Pages CI/CD baked in.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev src --port 3000",
    "lint": "eslint src/ functions/ tests/",
    "test": "node --test tests/functions.test.js tests/visits.test.js",
    "deploy": "wrangler pages deploy src --project-name $npm_package_name",
    "version:patch": "node scripts/bump-version.cjs patch",
    "version:minor": "node scripts/bump-version.cjs minor",
    "version:major": "node scripts/bump-version.cjs major",
    "postinstall": "node scripts/check-placeholders.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/YOUR_SITE.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "wrangler": "^4.87.0"
  }
}
